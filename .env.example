# ── Frontend (browser-exposed) ──────────────────────────────────────────────
# Anything prefixed with VITE_ is bundled into the client JS and is PUBLIC.
# Only the Supabase URL + publishable (anon) key belong here — they are safe to
# expose because Row Level Security restricts what the anon role can do.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ── Server-only (Vercel Functions / `vercel dev`) ───────────────────────────
# These are NEVER prefixed with VITE_, so Vite will not leak them to the browser.
# They are read only inside /api/* serverless functions.
#
# The catalog comes from Deezer's public API, which needs no key — so the only
# server secret is the Supabase service-role key. It bypasses RLS and is used
# ONLY by /api/songs to seed the read-only `songs` table. Never put it in client
# code or a VITE_ var.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Protects the /api/songs seeding endpoint. Set this in Vercel (production) so the
# daily cron can authenticate (Vercel sends `Authorization: Bearer <CRON_SECRET>`)
# and nobody else can trigger a re-seed. Leave unset locally to keep manual seeding
# easy. Generate with: openssl rand -hex 32
CRON_SECRET=your_random_cron_secret
